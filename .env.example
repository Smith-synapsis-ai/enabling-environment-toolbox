# Database (local Docker Compose)
DATABASE_URL=postgresql+asyncpg://ee_user:ee_dev_password@localhost:5433/ee_toolbox
DATABASE_URL_SYNC=postgresql://ee_user:ee_dev_password@localhost:5433/ee_toolbox

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Admin panel
# SECURITY: there is NO usable default. Admin login fails CLOSED unless a strong
# password (>= 12 chars, not a placeholder) is set here for local dev. In prod
# this is injected from Secrets Manager (ee-toolbox-api-keys) by entrypoint.sh.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# CORS (comma-separated origins, or "*" for all)
CORS_ORIGINS=*

# Model settings (optional)
DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_SECONDS=120
